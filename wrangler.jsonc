{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "broadsheet",
  "account_id": "779037e608ab1102679ef8b1bd499d49",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  // The canonical URL is the one we control; disable the workers.dev subdomain.
  // The apps.mrida.ng zone must be attached to this Cloudflare account.
  "workers_dev": false,
  "routes": [{ "pattern": "broadsheet.apps.mrida.ng", "custom_domain": true }],
  // Daily scrape: the scheduled() handler refreshes every feed at 06:00 UTC.
  "triggers": { "crons": ["0 6 * * *"] },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "broadsheet-db",
      "database_id": "eb5dc629-c6b1-4cc0-9b60-4a5b313edb54",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    // BASE_URL is set per-environment; for production it must match the
    // registered Google OAuth redirect origin. Secrets (GOOGLE_CLIENT_ID,
    // GOOGLE_CLIENT_SECRET, SESSION_SECRET, ANTHROPIC_API_KEY) are set with
    // `wrangler secret put`, never committed.
    "BASE_URL": "https://broadsheet.apps.mrida.ng"
  },
  "observability": { "enabled": true }
}
