# Cloudflare Workers Assets header rules (overrides OpenNext's default
# `max-age=0, must-revalidate` on static assets).

# Content-hashed build output — the filename changes whenever the bytes
# change, so it is safe to cache forever.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Un-hashed public files — cache for a day; they change rarely.
/favicon.ico
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400
